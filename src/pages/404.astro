---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="That page doesn't exist (yet)." canonical="/404">
  <section class="mx-auto flex max-w-xl flex-col items-center px-6 py-24 text-center">
    <p class="font-mono text-xs uppercase tracking-widest text-accent">Error 404</p>
    <h1 class="mt-3 font-display text-5xl font-semibold tracking-tight">
      That page wandered off.
    </h1>
    <p class="mt-4 text-text-muted">
      Either it never existed, or it's hiding behind a tall patch of grass.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded border border-border bg-surface px-4 py-2 text-sm text-text-muted transition-colors hover:border-accent/50 hover:text-text"
    >
      <span aria-hidden="true">←</span>
      <span>Back home</span>
    </a>
  </section>
</BaseLayout>
