---
import { type CollectionEntry, getCollection } from 'astro:content';
import ProseLayout from '../../layouts/ProseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'work'> };
const { entry } = Astro.props;
const { title, summary, role, year, tags, links, whatItIs, built, whatNext } = entry.data;

// Tiny inline-markdown renderer for **bold** and `code`. Headings/lists are
// handled by the structured schema, so we only need these two inline marks.
function inlineMd(s: string): string {
  return s
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
}
---

<ProseLayout title={title} description={summary}>
  <p class="mb-1 text-xs font-medium uppercase tracking-widest text-accent not-prose">
    {year} · {role}
  </p>
  <h1>{title}</h1>
  <p class="lead text-text-muted">{summary}</p>

  {
    tags.length > 0 && (
      <ul class="not-prose mt-4 flex flex-wrap gap-2 text-xs">
        {tags.map((t) => (
          <li class="rounded-sm border border-border bg-surface px-2 py-0.5 text-text-muted">
            {t}
          </li>
        ))}
      </ul>
    )
  }

  {
    links.length > 0 && (
      <ul class="not-prose mt-4 flex flex-wrap gap-2 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={l.url}
              class="rounded border border-border bg-surface px-3 py-1.5 text-text-muted no-underline transition-colors hover:border-accent/50 hover:text-text"
              target="_blank"
              rel="noopener"
            >
              {l.label} ↗
            </a>
          </li>
        ))}
      </ul>
    )
  }

  <hr class="my-8 border-border" />

  <h2>What it is</h2>
  <p set:html={inlineMd(whatItIs)} />

  <h2>What I built</h2>
  <ul>
    {built.map((b) => <li set:html={inlineMd(b)} />)}
  </ul>

  <h2>What I'd do next</h2>
  <p set:html={inlineMd(whatNext)} />

  <p class="mt-12 not-prose">
    <a href="/work" class="text-sm text-text-muted hover:text-accent">← All work</a>
  </p>
</ProseLayout>
