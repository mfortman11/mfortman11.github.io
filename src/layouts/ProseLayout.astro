---
import BaseLayout from './BaseLayout.astro';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
};

const props = Astro.props;
---

<BaseLayout {...props}>
  <article
    class="prose prose-neutral mx-auto max-w-2xl px-6 py-16 dark:prose-invert prose-headings:font-display prose-a:text-accent prose-a:no-underline hover:prose-a:underline"
  >
    <slot />
  </article>
</BaseLayout>
