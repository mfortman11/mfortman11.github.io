---
import type { CollectionEntry } from 'astro:content';
import { typeColors } from '../lib/typeColors';
import { render } from 'astro:content';

type Props = { entry: CollectionEntry<'pokemon'> };
const { entry } = Astro.props;
const { name, dex, types, sprite, role } = entry.data;
const { Content } = await render(entry);
---

<article
  class="group flex flex-col rounded-lg border border-border bg-surface p-4 transition-all hover:-translate-y-0.5 hover:shadow-lg"
>
  <div class="flex items-start gap-4">
    <img
      src={sprite}
      alt={`Official artwork of ${name}`}
      width="96"
      height="96"
      loading="lazy"
      class="h-24 w-24 shrink-0 object-contain"
    />
    <div class="min-w-0 flex-1">
      <div class="flex items-baseline justify-between gap-2">
        <h3 class="font-display text-lg font-semibold tracking-tight text-text">{name}</h3>
        <span class="font-mono text-xs text-text-muted">#{String(dex).padStart(3, '0')}</span>
      </div>
      <p class="mt-0.5 text-sm text-text-muted">{role}</p>
      <ul class="mt-2 flex flex-wrap gap-1">
        {
          types.map((t) => {
            const c = typeColors[t];
            return (
              <li
                class="rounded-sm border border-black/10 px-2 py-0.5 text-[10px] font-medium uppercase tracking-wider"
                style={`background-color: ${c.bg}; color: ${c.fg};`}
              >
                {t}
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>
  <details class="mt-3 text-sm">
    <summary
      class="cursor-pointer text-text-muted transition-colors hover:text-text marker:text-accent"
    >
      Why this pick
    </summary>
    <div class="mt-2 text-text-muted">
      <Content />
    </div>
  </details>
</article>
