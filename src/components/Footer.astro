---
import { socials } from '../lib/socials';
import { siteName } from '../lib/seo';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border/60">
  <div
    class="mx-auto flex max-w-5xl flex-col items-start justify-between gap-4 px-6 py-8 text-sm text-text-muted sm:flex-row sm:items-center"
  >
    <p>© {year} {siteName}</p>
    <ul class="flex flex-wrap items-center gap-x-4 gap-y-2">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              class="transition-colors hover:text-text"
              rel={s.href.startsWith('http') ? 'me noopener' : undefined}
              target={s.href.startsWith('http') ? '_blank' : undefined}
            >
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
