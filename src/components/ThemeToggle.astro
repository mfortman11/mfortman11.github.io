---
// Sun/moon toggle. Writes to localStorage and dispatches a `themechange`
// CustomEvent so other scripts (e.g. theme-aware D3 charts) can react.
//
// The no-flash script that sets the initial class lives in BaseLayout.astro
// and runs synchronously before paint.
---

<button
  type="button"
  id="theme-toggle"
  class="inline-flex h-9 w-9 items-center justify-center rounded text-text-muted transition-colors hover:bg-surface-2 hover:text-text"
  aria-label="Toggle color theme"
  aria-pressed="false"
>
  {/* Sun (shown in dark mode) */}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden h-5 w-5 dark:block"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  {/* Moon (shown in light mode) */}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-5 w-5 dark:hidden"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  // Re-runnable so it survives ClientRouter view transitions.
  function bindThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.bound === 'true') return;
    btn.dataset.bound = 'true';

    const sync = () => {
      const isDark = document.documentElement.classList.contains('dark');
      btn.setAttribute('aria-pressed', String(isDark));
    };
    sync();

    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const next = root.classList.toggle('dark') ? 'dark' : 'light';
      localStorage.setItem('theme', next);
      sync();
      document.dispatchEvent(new CustomEvent('themechange', { detail: next }));
    });
  }

  bindThemeToggle();
  document.addEventListener('astro:after-swap', bindThemeToggle);
</script>
