---
import type { CollectionEntry } from 'astro:content';

type Props = { entry: CollectionEntry<'nba'> };
const { entry } = Astro.props;
const { name, rank, consensusRank, era, teams, accolades, photo, blurb } = entry.data;

// YAML `>` folds single newlines to spaces and preserves blank lines as
// paragraph breaks — split on double newline to render proper <p>s.
const paragraphs = blurb.split(/\n\s*\n/).map((p) => p.trim()).filter(Boolean);

// Consensus delta — "matches", "+3 from consensus", "-2 from consensus".
// `arrow` is a leading glyph: ▲ when I rank them higher than consensus,
// ▼ when lower, • on an exact match.
let consensusLabel: string | null = null;
let consensusArrow: '▲' | '▼' | '•' = '•';
let consensusTone: 'match' | 'up' | 'down' = 'match';
if (consensusRank != null) {
  const delta = consensusRank - rank; // +ve = I rank them higher than consensus
  if (delta === 0) consensusLabel = 'Matches consensus';
  else if (delta > 0) {
    consensusLabel = `+${delta} vs consensus`;
    consensusTone = 'up';
    consensusArrow = '▲';
  } else {
    consensusLabel = `${delta} vs consensus`;
    consensusTone = 'down';
    consensusArrow = '▼';
  }
}

// Era-keyed accent band — same map as before, extended for older decades.
const eraTint: Record<string, string> = {
  '1950s': 'hsl(48 80% 55% / 0.22)',
  '1950s–1960s': 'hsl(42 80% 55% / 0.22)',
  '1960s': 'hsl(38 80% 55% / 0.22)',
  '1960s–1970s': 'hsl(28 78% 55% / 0.22)',
  '1970s': 'hsl(20 75% 55% / 0.22)',
  '1970s–1980s': 'hsl(10 75% 58% / 0.22)',
  '1980s': 'hsl(0 75% 60% / 0.22)',
  '1980s–1990s': 'hsl(330 70% 55% / 0.22)',
  '1980s–2000s': 'hsl(310 70% 58% / 0.22)',
  '1990s': 'hsl(290 65% 60% / 0.22)',
  '1990s–2000s': 'hsl(270 70% 65% / 0.22)',
  '1990s–2010s': 'hsl(260 70% 65% / 0.22)',
  '2000s': 'hsl(210 70% 60% / 0.22)',
  '2000s–2010s': 'hsl(190 70% 55% / 0.22)',
  '2000s–2020s': 'hsl(180 70% 50% / 0.22)',
  '2010s': 'hsl(170 65% 50% / 0.22)',
  '2010s–2020s': 'hsl(150 60% 50% / 0.22)',
  '2020s': 'hsl(130 60% 50% / 0.22)',
};
const tint = eraTint[era] ?? 'hsl(252 70% 60% / 0.22)';

const toneClass =
  consensusTone === 'up'
    ? 'text-success'
    : consensusTone === 'down'
      ? 'text-danger'
      : 'text-text-muted';
---

<article
  tabindex="0"
  class="player-card group relative flex w-full gap-4 overflow-hidden rounded-lg border border-border bg-surface p-3 pl-5 transition-colors hover:border-accent/40 focus-within:border-accent/40"
>
  <span
    aria-hidden="true"
    class="absolute inset-y-0 left-0 w-1.5"
    style={`background-color: ${tint};`}
  ></span>

  {/* Big rank — always visible on the left. */}
  <div
    aria-hidden="true"
    class="grid h-12 w-12 shrink-0 place-items-center rounded-md bg-surface-2 font-display text-2xl font-semibold tabular-nums text-text"
  >
    {rank}
  </div>

  {
    photo && (
      <img
        src={photo}
        alt={name}
        width="48"
        height="48"
        loading="lazy"
        class="h-12 w-12 shrink-0 rounded-md object-cover"
      />
    )
  }

  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
      <h3 class="font-display text-base font-semibold tracking-tight text-text">{name}</h3>
      <span class="text-xs text-text-muted">{era}</span>
      {
        consensusLabel && (
          <span class={`ml-auto flex items-center gap-1 font-mono text-[11px] uppercase tracking-wider ${toneClass}`}>
            <span aria-hidden="true" class="text-sm leading-none">
              {consensusArrow}
            </span>
            <span>{consensusLabel}</span>
          </span>
        )
      }
    </div>
    <p class="text-xs text-text-muted">{teams.join(' · ')}</p>

    {/* Expand-on-hover region — uses grid-template-rows trick for smooth
        height animation without measuring content. */}
    <div class="card-expand">
      <div class="min-h-0 overflow-hidden">
        {
          accolades.length > 0 && (
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {accolades.map((a) => (
                <li class="rounded-sm border border-border bg-bg px-2 py-0.5 text-[11px] text-text-muted">
                  {a}
                </li>
              ))}
            </ul>
          )
        }
        <div class="mt-3 space-y-2 text-sm leading-relaxed text-text-muted">
          {paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  .card-expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration) var(--ease-out);
  }
  .player-card:hover .card-expand,
  .player-card:focus-within .card-expand {
    grid-template-rows: 1fr;
  }
  @media (prefers-reduced-motion: reduce) {
    .card-expand {
      transition: none;
    }
  }
</style>
