---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';

type Props = { entry: CollectionEntry<'nba'> };
const { entry } = Astro.props;
const { name, rank, era, teams, accolades, photo } = entry.data;
const { Content } = await render(entry);

// Subtle era-keyed accent band on the left.
const eraTint: Record<string, string> = {
  '1960s': 'hsl(38 80% 55% / 0.18)',
  '1970s': 'hsl(20 75% 55% / 0.18)',
  '1980s': 'hsl(0 75% 60% / 0.18)',
  '1980s–1990s': 'hsl(330 70% 55% / 0.18)',
  '1990s': 'hsl(290 65% 60% / 0.18)',
  '1990s–2000s': 'hsl(250 70% 65% / 0.18)',
  '2000s': 'hsl(210 70% 60% / 0.18)',
  '2000s–2010s': 'hsl(190 70% 55% / 0.18)',
  '2010s': 'hsl(170 65% 50% / 0.18)',
  '2010s–2020s': 'hsl(150 60% 50% / 0.18)',
  '2020s': 'hsl(130 60% 50% / 0.18)',
};
const tint = eraTint[era] ?? 'hsl(252 70% 60% / 0.18)';
---

<article
  class="relative flex gap-5 overflow-hidden rounded-lg border border-border bg-surface p-5 pl-6"
>
  <span
    aria-hidden="true"
    class="absolute inset-y-0 left-0 w-1"
    style={`background-color: ${tint}; box-shadow: inset 0 0 0 9999px ${tint};`}
  ></span>
  <div
    aria-hidden="true"
    class="grid h-14 w-14 shrink-0 place-items-center rounded-md bg-surface-2 font-display text-2xl font-semibold tabular-nums text-text-muted"
  >
    {rank}
  </div>
  {
    photo && (
      <img
        src={photo}
        alt={name}
        width="80"
        height="80"
        loading="lazy"
        class="h-20 w-20 shrink-0 rounded-md object-cover"
      />
    )
  }
  <div class="min-w-0 flex-1">
    <h3 class="font-display text-xl font-semibold tracking-tight text-text">{name}</h3>
    <p class="mt-0.5 text-xs text-text-muted">
      {era} · {teams.join(', ')}
    </p>
    {
      accolades.length > 0 && (
        <ul class="mt-2 flex flex-wrap gap-1.5">
          {accolades.map((a) => (
            <li class="rounded-sm border border-border bg-bg px-2 py-0.5 text-[11px] text-text-muted">
              {a}
            </li>
          ))}
        </ul>
      )
    }
    <div class="prose prose-sm mt-3 max-w-none text-text-muted dark:prose-invert">
      <Content />
    </div>
  </div>
</article>
